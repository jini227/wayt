EXPO_PUBLIC_API_BASE_URL=http://localhost:19191/api

# Required. Expo Go is not enough for the native Kakao SDK; use an EAS development build.
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=
EXPO_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# Required. This is the Naver Maps NCP Key ID used by the native map SDK.
EXPO_PUBLIC_NAVER_MAPS_NCP_KEY_ID=
